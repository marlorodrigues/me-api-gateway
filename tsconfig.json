{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {

    "module": "nodenext",
    "target": "esnext",
    "outDir": "build",
    "lib": ["esnext"],
    "types": ["node"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    
  },
  "exclude": [
    "node_modules/",
    "__tests__/",
    "prisma/",
    "build/",
    "docs",
    "logs",
    "tmp"
  ]
}
